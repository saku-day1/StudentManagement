<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="raisetech.StudentManagement.repository.StudentSearchRepository">

    <!-- 検索条件に基づいて受講生サマリー情報を検索する -->
    <select id="searchStudentSummaries"
            parameterType="raisetech.StudentManagement.dto.StudentSearchCriteria"
            resultType="raisetech.StudentManagement.dto.StudentSearchSummary">
        SELECT
        s.id AS studentId,
        sc.id AS studentCourseId,
        s.name,
        s.furigana,
        s.email,
        sc.course_name AS courseName,
        a.status
        FROM students s
        JOIN student_courses sc
        ON s.id = sc.student_id
        LEFT JOIN application_status a
        ON sc.id = a.student_course_id
        <where>
            <if test="name != null and name != ''">
                AND s.name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="furigana != null and furigana != ''">
                AND s.furigana LIKE CONCAT('%', #{furigana} ,'%')
            </if>
            <if test="courseName != null and courseName != ''">
                AND sc.course_name = #{courseName}
            </if>
            <if test="studentId != null">
                AND s.id = #{studentId}
            </if>
            <if test="studentCourseId != null">
                AND sc.id = #{studentCourseId}
            </if>
            <if test="status != null and status != ''">
                AND a.status = #{status}
            </if>
        </where>
    </select>
</mapper>